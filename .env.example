# QA Office — environment variables
# Copy to .env and fill in values. Never commit .env to git.

# ── AI Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Frontend → Backend proxy ──────────────────────────────────────────────────
# Set this in frontend/.env.local too (without NEXT_PUBLIC_ prefix — server-only)
BACKEND_URL=http://127.0.0.1:8005

# ── CORS allowed origins (comma-separated) ────────────────────────────────────
CORS_ORIGINS=http://localhost:3005,http://127.0.0.1:3005

# ── Auth (Clerk) — optional, only needed for protected test targets ───────────
CLERK_SECRET_KEY=

# ── Target app under test (NEVER production) ─────────────────────────────────
APP_TEST_URL=https://staging.yourapp.com
APP_USERNAME=qa-user@yourapp.com
APP_PASSWORD=

# ── Playwright ────────────────────────────────────────────────────────────────
HEADLESS=true
TIMEOUT_MS=30000
SCREENSHOT_EACH_STEP=true

# ── Retry settings ────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BACKOFF_BASE_MS=1000
